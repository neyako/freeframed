APP_ENV=development
LOCAL_MODE=true
DATABASE_URL=postgresql://freeframe:freeframe@postgres:5432/freeframe
REDIS_URL=redis://redis:6379/0
S3_BUCKET=freeframe
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SETUP_TOKEN=
TRANSCODER_ENGINE=ffmpeg

# Hardware-accelerated transcode. "auto" detects nvenc/qsv/vaapi, else software.
# Force one of: nvenc | qsv | vaapi | software. Requires GPU device passthrough at runtime.
TRANSCODE_HWACCEL=auto
TRANSCODE_VAAPI_DEVICE=/dev/dri/renderD128

# 0 disables scheduled purge.
TRASH_RETENTION_DAYS=30
